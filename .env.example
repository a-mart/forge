# Core (legacy MIDDLEMAN_* names are still accepted)
# FORGE_HOST=127.0.0.1
# FORGE_PORT=47187
# FORGE_DATA_DIR=~/.forge
# FORGE_DEBUG=false          # Also enables extension tool-call logging
# FORGE_TELEMETRY=false      # Disable anonymous telemetry (enabled by default)
# FORGE_CORTEX_ENABLED=true  # Disable Cortex (AI self-improvement and knowledge management)
# FORGE_RUNTIME_TARGET=builder

# UI (legacy VITE_MIDDLEMAN_WS_URL is still accepted)
# VITE_FORGE_WS_URL=ws://127.0.0.1:47187

# Skills
# BRAVE_API_KEY=
# GEMINI_API_KEY=

# Collaboration server (first boot requires admin credentials)
# Local docker-compose defaults to host port 47387 -> container port 47287.
# If you change FORGE_PUBLIC_PORT, update FORGE_COLLABORATION_BASE_URL to match.
# The docker-compose default trusted origins already allow local Forge UI/Electron dev on
# http://127.0.0.1:47188 and local preview on http://127.0.0.1:47189 when this variable is unset.
# Use 127.0.0.1 rather than localhost for local HTTP split deployments; mixing localhost and
# 127.0.0.1 becomes cross-site for cookies and would require HTTPS.
# FORGE_PUBLIC_PORT=47387
# FORGE_ADMIN_EMAIL=admin@example.com
# FORGE_ADMIN_PASSWORD=change-me
# FORGE_COLLABORATION_BASE_URL=http://127.0.0.1:47387
# FORGE_COLLABORATION_TRUSTED_ORIGINS=http://127.0.0.1:47188,http://127.0.0.1:47189,https://app.example.com
# FORGE_COLLABORATION_AUTH_SECRET=

# Agent Runtimes

# Playwright (macOS/Linux only; legacy MIDDLEMAN_* name still accepted)
# FORGE_PLAYWRIGHT_DASHBOARD_ENABLED=false

# Electron signing / packaging examples
# macOS signing + notarization:
# APPLE_ID=developer@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=ABCDE12345
# Windows signing (optional):
# CSC_LINK=base64-or-file-path-to-pfx
# CSC_KEY_PASSWORD=your-certificate-password
# WIN_CSC_LINK=base64-or-file-path-to-pfx
# WIN_CSC_KEY_PASSWORD=your-certificate-password

# Embedded Git versioning for durable Cortex/prompt/reference file history (optional advanced settings)
# Defaults if unset:
# - FORGE_VERSIONING_ENABLED=true (legacy MIDDLEMAN_VERSIONING_ENABLED also accepted)
# - FORGE_VERSIONING_TRACK_SESSION_MEMORY=false (legacy MIDDLEMAN_VERSIONING_TRACK_SESSION_MEMORY also accepted)
# - FORGE_VERSIONING_RECONCILE_INTERVAL_MS=300000 (legacy MIDDLEMAN_VERSIONING_RECONCILE_INTERVAL_MS also accepted)
# FORGE_VERSIONING_ENABLED=true
# FORGE_VERSIONING_TRACK_SESSION_MEMORY=false
# FORGE_VERSIONING_RECONCILE_INTERVAL_MS=300000
