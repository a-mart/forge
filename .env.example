# Core
# MIDDLEMAN_HOST=127.0.0.1
# MIDDLEMAN_PORT=47187
# MIDDLEMAN_DATA_DIR=~/.middleman
# MIDDLEMAN_DEBUG=false

# UI
# VITE_MIDDLEMAN_WS_URL=ws://127.0.0.1:47187

# Skills
# BRAVE_API_KEY=
# GEMINI_API_KEY=

# Agent Runtimes
# CODEX_API_KEY=
# CODEX_BIN=codex

# Playwright (macOS/Linux only)
# MIDDLEMAN_PLAYWRIGHT_DASHBOARD_ENABLED=false

# Embedded Git versioning for durable Cortex/prompt/reference file history (optional advanced settings)
# Defaults if unset:
# - MIDDLEMAN_VERSIONING_ENABLED=true
# - MIDDLEMAN_VERSIONING_TRACK_SESSION_MEMORY=false
# - MIDDLEMAN_VERSIONING_RECONCILE_INTERVAL_MS=300000
# MIDDLEMAN_VERSIONING_ENABLED=true
# MIDDLEMAN_VERSIONING_TRACK_SESSION_MEMORY=false
# MIDDLEMAN_VERSIONING_RECONCILE_INTERVAL_MS=300000
