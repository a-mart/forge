{
  "name": "forge",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/backend",
    "apps/ui",
    "apps/electron",
    "packages/protocol"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names backend,ui \"pnpm --filter @forge/backend dev\" \"pnpm --filter @forge/ui dev\"",
    "dev:backend": "pnpm --filter @forge/backend dev",
    "dev:ui": "pnpm --filter @forge/ui dev",
    "dev:electron": "concurrently --kill-others-on-fail -n ui,electron -c green,magenta \"pnpm dev:ui\" \"wait-on tcp:127.0.0.1:47188 && cd apps/electron && pnpm dev\"",
    "build": "pnpm --filter @forge/protocol build && pnpm --filter @forge/backend build && pnpm --filter @forge/ui build",
    "build:electron": "pnpm --filter @forge/electron run build:all",
    "model-catalog:audit": "node scripts/model-catalog-audit.mjs",
    "package:electron": "pnpm --filter @forge/electron run package",
    "release:electron": "cd apps/electron && node scripts/release.mjs",
    "prod": "pnpm build && pnpm prod:start",
    "prod:start": "node scripts/check-data-migration.mjs && concurrently --kill-others-on-fail --names backend,ui \"cross-env NODE_ENV=production FORGE_PORT=47287 pnpm --filter @forge/backend start\" \"pnpm --filter @forge/ui preview\"",
    "prod:daemon": "node scripts/prod-daemon.mjs",
    "prod:restart": "node scripts/prod-daemon-restart.mjs",
    "test": "pnpm --filter @forge/backend test && pnpm --filter @forge/ui test",
    "postinstall": "node scripts/fix-node-pty-spawn-helper-permissions.mjs"
  },
  "pnpm": {
    "overrides": {
      "zod": "^4.3.6",
      "@tanstack/router-generator>zod": "3.25.76",
      "@tanstack/router-plugin>zod": "3.25.76",
      "@tanstack/start-plugin-core>zod": "3.25.76"
    },
    "patchedDependencies": {
      "@mariozechner/pi-coding-agent@0.63.1": "patches/@mariozechner__pi-coding-agent@0.63.1.patch"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "electron",
      "node-pty"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.5"
  }
}
