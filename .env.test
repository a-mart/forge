# Isolated local test environment for integrated terminal testing (worktree only)
# Do not use this to run against production data.
FORGE_HOST=127.0.0.1
FORGE_PORT=47387
FORGE_DATA_DIR=/Users/adam/.forge-terminal-test

# UI uses this to connect to the isolated backend when running `vite dev`.
VITE_FORGE_WS_URL=ws://127.0.0.1:47387

# Optional terminal test convenience
FORGE_TERMINAL_ENABLED=true
